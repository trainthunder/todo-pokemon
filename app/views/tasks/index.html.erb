<!-- filepath: app/views/tasks/index.html.erb -->
<div class="pokemon-container">
  <header class="pokemon-header">
    <h1>⚡ Pokemon Todo List ⚡</h1>
    <p class="pokemon-subtitle">Gotta Complete 'Em All!</p>
  </header>

  <div class="filter-tabs">
    <%= link_to "All", tasks_path(filter: nil), class: filter_class(nil) %>
    <%= link_to "Active", tasks_path(filter: 'active'), class: filter_class('active') %>
    <%= link_to "Completed", tasks_path(filter: 'completed'), class: filter_class('completed') %>
  </div>

  <div class="task-form-container">
    <%= render 'form', task: Task.new %>
  </div>

  <div class="task-list">
    <% if @tasks.any? %>
      <% @tasks.each do |task| %>
        <div class="task-card <%= 'completed' if task.completed %>">
          <div class="task-content">
            <div class="task-title"><%= task.title %></div>
            <% if task.description.present? %>
              <div class="task-description"><%= task.description %></div>
            <% end %>
          </div>
          
          <div class="task-actions">
            <%= button_to toggle_complete_task_path(task), 
                method: :patch, 
                class: "btn-toggle #{task.completed ? 'btn-complete' : 'btn-pending'}",
                title: task.completed ? "Mark as incomplete" : "Mark as complete" do %>
              <%= task.completed ? "✓" : "○" %>
            <% end %>
            
            <%= link_to "Edit", edit_task_path(task), class: "btn-edit" %>
            <%= button_to "Delete", task_path(task), 
                method: :delete, 
                data: { confirm: "Are you sure you want to release this task?" },
                class: "btn-delete" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        <div class="pokeball-icon">⚪</div>
        <p>No tasks found! Time to catch 'em all!</p>
      </div>
    <% end %>
  </div>

  <footer class="pokemon-footer">
    <p>🌟 <%= Task.count %> tasks registered | <%= Task.where(completed: true).count %> completed</p>
  </footer>
</div>